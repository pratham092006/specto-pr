# API Configuration - Choose one option below:

# Option 1: Groq API (FREE - Recommended for testing)
# Sign up at: https://console.groq.com/keys
USE_OPENAI=true
OPENAI_API_URL=https://api.groq.com/openai/v1
OPENAI_API_KEY=gsk_your_groq_api_key_here

# Option 2: OpenAI API (Paid)
# Get key from: https://platform.openai.com/api-keys
# USE_OPENAI=true
# OPENAI_API_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-your_openai_api_key_here

# Option 3: IBM Bob API (Original)
# BOB_API_URL=https://api.bob.com
# BOB_API_KEY=your_bob_api_key_here

# GitHub Configuration (Required)
# Get token from: https://github.com/settings/tokens
# Required scope: repo
GITHUB_TOKEN=your_github_personal_access_token_here

# Server Configuration
PORT=3001
NODE_ENV=development

# Optional: Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100